{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "demogrill/call-to-action",
    "title": "DemoGrill Call-To-Action block",
    "icon": "button",
    "description": "Call-To-Action block in DemoGrill Project.",
    "category":"demogrill",
    "keywords": [ "CTA", "people" ],
    "version": "1",
    "textdomain": "demogrill",
    "editorScript":"file:./index.js",
    "style": "file:./index.css",
    "attributes": {
        "ctaTitle":{
            "type":"string"
        },
        "ctaText":{
            "type":"string"
        },
        "btnText":{
            "type":"string",
            "default":"Click Here"
        },
        "paddingBtnX":{
            "type":"number",
            "default":40
        },
        "paddingBtnY":{
            "type":"number",
            "default":20
        },
        "btnURL":{
            "type":"string",
            "default":"#"
        },
        "backColor":{
            "type":"string",
            "default":"#ff6600"
        },
        "textColor":{
            "type":"string",
            "default":"#000000"
        },
        "btnBackground":{
            "type":"string",
            "default": "#000000"
        },
        "btnTextColor":{
            "type":"string",
            "default": "#000000"
        }
    }
   }